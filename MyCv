<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>My CV</title>

  
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <style>
    body{
      background-color:#f4f4f4;
    }

    .cv-container{
      max-width:900px;
      margin:auto;
      margin-top:40px;
      background:white;
      padding:30px;
      border-radius:15px;
      box-shadow:0 0 10px rgba(0,0,0,0.1);
    }

    .profile-img{
      width:180px;
      height:180px;
      object-fit:cover;
      border-radius:50%;
      border:5px solid #0d6efd;
    }

    .section-title{
      margin-top:30px;
      margin-bottom:15px;
      color:#0d6efd;
      border-bottom:2px solid #0d6efd;
      display:inline-block;
      padding-bottom:5px;
    }
  </style>
</head>

<body>

  <div class="container">
    <div class="cv-container">

      <!-- Header -->
      <div class="text-center">
        <img src="myphoto.jpg" class="profile-img" alt="Profile Image">

        <h1 class="mt-3">Azaam ALDarwish</h1>

        <h4 class="text-muted">
          Frontend Developer
        </h4>
      </div>

      
      <h3 class="section-title">About Me</h3>

      <p>
        I am a computer science student interested in web development
        and Flutter application development.
      </p>

     
      <h3 class="section-title">Skills</h3>

      <div class="row">

        <div class="col-md-4">
          <div class="alert alert-primary text-center">
            HTML
          </div>
        </div>

        <div class="col-md-4">
          <div class="alert alert-success text-center">
            CSS
          </div>
        </div>

        <div class="col-md-4">
          <div class="alert alert-warning text-center">
            Bootstrap
          </div>
        </div>

        <div class="col-md-4">
          <div class="alert alert-info text-center">
            JavaScript
          </div>
        </div>

      </div>

      
      <h3 class="section-title">Education</h3>

      <ul class="list-group">
        <li class="list-group-item">
          Technical College - Computer Science
        </li>
      </ul>

      
      <h3 class="section-title">Contact</h3>

      <div class="card p-3">
        <p>Email: ali@email.com</p>
        <p>Phone: 0500000000</p>
      </div>

    </div>
  </div>

</body>
</html>
