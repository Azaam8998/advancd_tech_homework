<!DOCTYPE html>
<html>
<body>

<div class="container text-center">
  <div class="row">
    <div class="col">

      <label>number 1</label>
      <input type="text" name="number1" id="number1" placeholder="enter single digit number" value="1"><br>
      <label>number 2</label>
      <input type="text" name="number2" id="number2" placeholder="enter single digit number" value="2"><br>

      <label>number 3</label>
      <input type="text" name="number2" id="number3" placeholder="enter single digit number" value="3"><br>
      
    
      <button type="text" class="btn btn-info" onclick="submit1()">submit</button>
      <button type="text" class="btn btn-info" onclick="submit2()">submit</button>
      <button type="text" class="btn btn-info" onclick="submit3()">submit</button>

     
      <div style="margin-top: 20px;">
        <h2>النتيجة:</h2>
        <h3 id="screen1"></h3>
      </div>

    </div>
  </div>
</div>

<script>
function submit1(){
    var a = document.getElementById("number1").value;
    var b = document.getElementById("number2").value;
    var c = parseInt(a) + parseInt(b);
    document.getElementById("screen1").innerHTML = c;
}
 function submit2(){
    var a = document.getElementById("number1").value;
    var b = document.getElementById("number2").value;
    var c = parseInt(a) * parseInt(b);
    document.getElementById("screen1").innerHTML = c;
}
function submit3(){
    var a = document.getElementById("number1").value;
    var b = document.getElementById("number2").value;
    var c = parseInt(a) < parseInt(b);
    document.getElementById("screen1").innerHTML = c;
}
</script>
     <script src="/docs/5.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
